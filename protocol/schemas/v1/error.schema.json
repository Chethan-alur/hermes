{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hermes.local/protocol/v1/error.schema.json",
  "title": "HermesErrorMessage",
  "description": "Protocol contract schema for system or speech error notifications.",
  "type": "object",
  "required": ["version", "type", "code", "message", "timestamp"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "type": {
      "type": "string",
      "const": "error"
    },
    "code": {
      "type": "string",
      "description": "Canonical error code. Enumerates every code emitted by the Android engine (see getErrorCodeString in TransportServerService.kt) plus the transport/permission codes used by the Windows and transport layers.",
      "enum": [
        "SPEECH_TIMEOUT",
        "AUDIO_RECORD_ERROR",
        "ENGINE_UNAVAILABLE",
        "PERMISSION_DENIED",
        "TRANSPORT_ERROR",
        "UNKNOWN_ERROR",
        "NETWORK_TIMEOUT",
        "NETWORK_ERROR",
        "SERVER_ERROR",
        "CLIENT_ERROR",
        "NO_MATCH",
        "RECOGNIZER_BUSY",
        "INSUFFICIENT_PERMISSIONS"
      ]
    },
    "message": {
      "type": "string",
      "description": "Human-readable diagnostic message."
    },
    "timestamp": {
      "type": "integer",
      "description": "Unix timestamp in milliseconds when error occurred."
    }
  },
  "additionalProperties": false
}
